{
  "name": "mtmauto",
  "version": "0.0.2",
  "description": "CLI demo for running Midscene-based Android cloud-phone automation flows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mtmauto": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeh007/mtmauto.git"
  },
  "homepage": "https://github.com/codeh007/mtmauto#readme",
  "bugs": {
    "url": "https://github.com/codeh007/mtmauto/issues"
  },
  "keywords": [
    "midscene",
    "android",
    "automation",
    "cloud-phone",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli/index.js",
    "demo": "tsx src/cli/index.ts hongguo run",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@midscene/android": "^1.0.20",
    "commander": "^13.1.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "4.21.0",
    "typescript": "^6.0.2"
  }
}
